# ── Maven / Java ──────────────────────────────────────────────
**/target/
**/bin/
**/out/
**/*.class
**/*.jar
!**/wrapper/**/*.jar

# ── Node / Angular ────────────────────────────────────────────
**/node_modules/
**/dist/
**/tmp/
**/out-tsc/
