!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────
*.log
/logs/

# ── Secrets / config locaux ───────────────────────────────────
.env
*.env.local
