{
  "info": {
    "name": "Fleet Backend",
    "_postman_id": "fleet-backend-collection",
    "description": "Quick API tests for fleet backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register User",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Admin123!\",\n  \"firstName\": \"Admin\",\n  \"lastName\": \"User\",\n  \"role\": \"ROLE_ADMIN\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/auth/register",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api","auth","register"]
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Admin123!\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api","auth","login"]
        }
      }
    },
    {
      "name": "Get Vehicles (fleet)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "http://localhost:8080/api/fleet/vehicles",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api","fleet","vehicles"]
        }
      }
    }
    ,
    {
      "name": "Get Mileage (fleet)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "http://localhost:8080/api/fleet/mileage?year={{year}}&month={{month}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api","fleet","mileage"],
          "query": [
            { "key": "year", "value": "{{year}}" },
            { "key": "month", "value": "{{month}}" }
          ]
        }
      }
    },
    {
      "name": "Get Missing (fleet)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "http://localhost:8080/api/fleet/missing?year={{year}}&month={{month}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api","fleet","missing"],
          "query": [
            { "key": "year", "value": "{{year}}" },
            { "key": "month", "value": "{{month}}" }
          ]
        }
      }
    },
    {
      "name": "Export CSV (fleet)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Accept", "value": "text/csv" }
        ],
        "url": {
          "raw": "http://localhost:8080/api/fleet/export?year={{year}}&month={{month}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api","fleet","export"],
          "query": [
            { "key": "year", "value": "{{year}}" },
            { "key": "month", "value": "{{month}}" }
          ]
        }
      }
    }
